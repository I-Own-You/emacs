(scroll-bar-mode -1)             ;; disable visible scrollbar (that on right)
(tool-bar-mode -1)               ;; disable toolbar (file, edit, setting on top, .etc)
(tooltip-mode -1)                ;; disable tooltips

(delete-selection-mode 1)        ;; remove selection after paste

(kill-ring-deindent-mode 1)      ;; make pasting more smarter

(menu-bar-mode -1)               ;; disable menu bar

(winner-mode 1)                  ;; to reopen splits 

(provide 'func)
